{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://board.me/schema/issue",
  "title": "Issue",
  "description": "An issue for board",
  "type": "object",
  "properties": {
    "id" : {
        "description": "The unique identifier for an issue",
        "type" : "string"
    },
    "title" : {
        "description": "The title for an issue",
        "type" : "string"
    },
    "body" : {
        "description": "The body of an issue",
        "type" : ["string","null"] 
    },
    "blocks" : {
        "description": "Still in thinking phase for body blocks.",
        "type" : ["array" ,"null"],
        "items": {
            "type" : "object"
        },
        "minItems": 1
    },

    "columnId" : {
        "description": "The id of collumn issue is in",
        "type" : ["string","null"] 
    },
    "tags" : {
      "description": "Tag ids for the product",
      "type": ["array","null"] ,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "priority" : {
        "description": "The numeric presentation of priority 1-5",
        "type" : "integer",
        "exclusiveMaximum": 6,
        "exclusiveMinimum": 0
        
    },
    "color" : {
        "description": "The color for an issue",
        "type" : ["string","null"]  
    },
    "createdAt" : {
        "description": "Creation date",
        "type" : "string" 
    },
    "updatedAt" : {
        "description": "Update date",
        "type" : ["string","null"] 
    },
    "archivedAt" : {
        "description": "Archive date",
        "type" : ["string","null"] 
    }

    
    
    
    
  },

  "required": [ "id" ,"title" ,"createdAt" ]
}

