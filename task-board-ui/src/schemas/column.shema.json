{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://board.me/schema/column",
  "title": "Column",
  "description": "A column for issues",
  "type": "object",
  "properties": {
    "id" : {
        "description": "Id of the column",
        "type" : "string"
    },
    "name" : {
        "description": "Name of the column",
        "type" : "string"
    },
    "color" : {
        "description": "color of the column",
        "type" : ["string","null"]
    },
        "createdAt" : {
        "description": "Creation date",
        "type" : "string" 
    },
    "updatedAt" : {
        "description": "Update date",
        "type" : ["string","null"] 
    },
    "archivedAt" : {
        "description": "Archive date",
        "type" : ["string","null"] 
    }           
  },
  "required": ["id","name"]
}

