{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://board.me/schema/board",
  "title": "Board",
  "description": "A board",
  "type": "object",
  "properties": {
    "id" : {
        "description": "Id of the board",
        "type" : "string"
    },
    "name" : {
        "description": "name of the board",
        "type" : "string"
    },
    "columns" : {
        "description": "registry of the columns used in board",
        "type" : ["object","null"],
        "additionalProperties": {
               "$ref": "https://board.me/schema/column"
        }
    },
    "issues" : {
        "description": "registry of the issues used in board",
        "type" : ["object","null"],
        "additionalProperties": {
            "$ref": "https://board.me/schema/issue"
        }
    },
    "columnOrder" : {
        "description": "order of the collumn ids used in board",
        "type" :  ["array","null"],
        "items": {
            "type": "string"
        }
        
    },
    "issueOrderByColumn" : {
        "description": "order of the issue ids used in boards column",
        "type" : ["object","null"],
        "additionalProperties": {
        "type": "array",
        "items": {
        "type": "string"
        }
    }

    }

  },
   "required": ["id","name"]
}
